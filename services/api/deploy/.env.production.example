# FlavorOS API — production environment variables
# Copy to /etc/flavoros/api.env on the VPS (chmod 600, owned by flavoros user)
# Never commit real values.

# ── Runtime ──────────────────────────────────────────────────────────────────
API_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# psycopg v3 driver prefix is required (config.py normalises bare postgres:// automatically)
DATABASE_URL=postgresql+psycopg://flavoros:<password>@localhost:5432/flavoros

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<generate-a-real-secret>
JWT_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list — must include your Vercel production URL
API_ORIGINS=https://flavoros.vercel.app,https://app.flavoros.cc

# ── Provider integrations ─────────────────────────────────────────────────────
COMPOSIO_API_KEY=<your-composio-api-key>
COMPOSIO_REDIRECT_URI=https://api.flavoros.cc/providers/callback

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Seed / dev ───────────────────────────────────────────────────────────────
# Demo login (matches apps/flavoros login pre-fill): tenant demo, client@demo.local / devclient
API_SKIP_STARTUP_SEED=false
DEV_CLIENT_PASSWORD=devclient
DEV_ADMIN_PASSWORD=devadmin

# ── GBrain ───────────────────────────────────────────────────────────────────
GBRAIN_ADAPTER=stub
