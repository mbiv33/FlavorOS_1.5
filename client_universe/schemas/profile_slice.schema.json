{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flavoros.local/schemas/profile_slice.json",
  "title": "ClientProfileSlice",
  "type": "object",
  "required": [
    "client_id",
    "status",
    "identity",
    "contexts",
    "authority_defaults",
    "onboarding"
  ],
  "properties": {
    "client_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "identity": {
      "type": "object",
      "required": ["display_name", "timezone"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["context_id", "context_type", "display_name", "status"],
        "properties": {
          "context_id": { "type": "string", "minLength": 1 },
          "context_type": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "context_accounts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "context_account_id",
                "provider",
                "context_account_purpose",
                "account_alias",
                "auth_scheme"
              ],
              "properties": {
                "context_account_id": { "type": "string", "minLength": 1 },
                "provider": { "type": "string", "minLength": 1 },
                "context_account_purpose": { "type": "string", "minLength": 1 },
                "account_alias": { "type": "string", "minLength": 1 },
                "auth_scheme": { "type": "string", "minLength": 1 },
                "oauth_connection_id": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "authority_defaults": {
      "type": "object",
      "required": [
        "outbound_comms",
        "calendar_commits",
        "travel_booking",
        "money_movement"
      ],
      "properties": {
        "outbound_comms": { "type": "string", "minLength": 1 },
        "calendar_commits": { "type": "string", "minLength": 1 },
        "travel_booking": { "type": "string", "minLength": 1 },
        "money_movement": { "type": "string", "minLength": 1 },
        "sensitive_relationship_actions": { "type": "string", "minLength": 1 },
        "irreversible_provider_actions": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "onboarding": {
      "type": "object",
      "required": ["status", "oauth_ready", "first_sync_verified"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "oauth_ready": { "type": "boolean" },
        "first_sync_verified": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
