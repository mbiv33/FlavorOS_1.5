# PostgreSQL (docker-compose default matches these)
DATABASE_URL=postgresql+psycopg://flavoros:flavoros@localhost:5432/flavoros

# API
API_ENV=development
API_ORIGINS=http://localhost:3000,http://localhost:3001
JWT_SECRET=change-me-use-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Require X-Client-ID on tenant routes when false (development relaxes unknown tenant check — keep false locally)
API_STRICT_TENANT=false

# Skip DB seed on API startup (health/OpenAPI still run; use when Postgres is not up yet)
API_SKIP_STARTUP_SEED=false

# Next.js apps (browser-visible API URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Default tenant slug for dev-only UI helpers (optional)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo

# Dev-only seed passwords (override in .env — defaults used if unset)
DEV_CLIENT_PASSWORD=devclient
DEV_ADMIN_PASSWORD=devadmin

# InstantDB (`apps/flavoros`) — copy vars into `apps/flavoros/.env.local`
# NEXT_PUBLIC_INSTANT_APP_ID=
# INSTANT_APP_ADMIN_TOKEN=
